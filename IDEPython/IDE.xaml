<Window x:Class="IDEPython.IDE"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="IDE" Height="820" Width="1550"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize" KeyDown="Window_KeyDown" VerticalAlignment="Center"
        WindowStyle="None" WindowState="Maximized" Topmost="True">
    <Grid Background="Black">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#FF635C5C">
            <Button x:Name="btnShowFiles" Content="📁" Width="30" Height="24" Background="#FFF6F676" Foreground="Black" Click="btnShowFiles_Click" Margin="10,0,0,0" FontWeight="Bold"/>
            <Button x:Name="btnRun" Content="▶" Width="25" Height="25" Background="#FF7CFF8D" Margin="10,0,10,0" Click="btnRun_Click" ToolTip="Run (F5 or CTRL+R)"/>
            <Button x:Name="btnStop" Content="⯃" Width="25" Height="25" Background="#FFE36565" Margin="0,0,10,0" Click="btnStop_Click"/>
            <Label x:Name="lblProjectName" Foreground="White" FontSize="14" VerticalAlignment="Center" Width="1100"/>

            <Grid Width="296" Margin="0,0,0,0" RenderTransformOrigin="0.811,0.526">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="181,0,0,0" Width="296">
                    <Button x:Name="btnUploadAssignment" Content="↑" Width="30" Height="25" Background="#5B5EC7" Foreground="White" Margin="0,0,10,0"/>
                    <Button x:Name="btnReturn" Content="x" Width="30" Height="25" Background="#FFFF1A45" Foreground="White" Margin="0,0,10,0" Click="btnReturn_Cick"/>
                </StackPanel>
            </Grid>
        </StackPanel>


        <Grid Grid.Row="1" Background="#FF352D2D">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="42"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- File explorer -->
            <Border x:Name="spFiles" Grid.Row="0" Grid.Column="0" Background="#2E2E2E" Padding="8">
                <StackPanel >
                    <TextBlock Text="Files" Foreground="White" FontWeight="Bold" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button x:Name="btnNewFile" Content="New File" Width="65" Height="24" Click="btnNewFile_Click" Margin="0,0,6,0"/>
                        <Button x:Name="btnNewFolder" Content="New Folder" Width="70" Height="24" Click="btnNewFolder_Click" Margin="0,0,6,0"/>
                        <Button x:Name="btnDelete" Content="Delete" Width="55" Height="24" Click="btnDelete_Click"/>
                    </StackPanel>
                    <TreeView x:Name="tvFiles" Foreground = "White" BorderThickness="0" SelectedItemChanged="tvFiles_SelectedItemChanged" BorderBrush="#FF0B57E0"/>
                </StackPanel>
            </Border>

            <TextBox Grid.Row="0" Grid.Column="1" x:Name="txtLineNumbers"
                     Background="#FF3C3C3C" Foreground="White" BorderThickness="0"
                     IsReadOnly="True" TextAlignment="Center" FontFamily="Consolas" FontSize="14"
                     Padding="0,10,0,0"
                     VerticalScrollBarVisibility="Hidden"/>

            <TextBox Grid.Row="0" Grid.Column="2" x:Name="txtEditor"
                     Background="#FF8E8E8E" Foreground="White" BorderThickness="0"
                     AcceptsReturn="True" AcceptsTab="True" FontFamily="Consolas" FontSize="14"
                     Padding="10,10,0,0" VerticalScrollBarVisibility="Auto"
                     Text="Write your code here..." GotFocus="txtEditor_Click" 
                     
                     
                     DataObject.Pasting="txtEditor_Pasting"  DataObject.Copying="txtEditor_Copying"  TextChanged="txtEditor_TextChanged_1"/>

            <GridSplitter x:Name="txtConsoleSeparator" Grid.Row="1" Grid.ColumnSpan="3" Height="5" 
                          HorizontalAlignment="Stretch" VerticalAlignment="Center" Background="Black"/>

            <TextBox Grid.Row="2" Grid.ColumnSpan="3" x:Name="txtConsole"
                     Background="Black"  FontFamily="Consolas" FontSize="12"
                     IsReadOnly="True" VerticalScrollBarVisibility="Auto" Padding="10" Height="120"/>
        </Grid>
    </Grid>
</Window>