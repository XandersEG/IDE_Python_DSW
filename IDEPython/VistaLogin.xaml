<Window x:Class="IDEPython.VistaLogin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Background="#5B5EC7" 
        Title="Login" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Border Background="White" 
                CornerRadius="15" 
                Width="350" 
                Height="350" 
                VerticalAlignment="Center" 
                HorizontalAlignment="Center">

            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Direction="270" ShadowDepth="3" Opacity="0.3"/>
            </Border.Effect>

            <StackPanel Margin="30">
                <TextBlock 
                           FontSize="26" 
                           FontWeight="Bold"
                           Foreground="#5B5EC7" 
                           HorizontalAlignment="Center" 
                           Margin="0,0,0,25"><Run Text="Inicio de Sesió"/><Run Language="es-es" Text="n"/></TextBlock>

                <TextBlock Text="Nombre de Usuario" Foreground="#707070" Margin="0,0,0,5" FontSize="11"/>
                <TextBox Margin="0,0,0,15" 
                         Padding="10,7" 
                         BorderBrush="#5B5EC7" 
                         BorderThickness="1.5"
                         VerticalContentAlignment="Center"
                         FontSize="13"/>

                <TextBlock Text="Contraseña" Foreground="#707070" Margin="0,0,0,5" FontSize="11"/>
                <PasswordBox Margin="0,0,0,25" 
                             Padding="10,7" 
                             BorderBrush="#5B5EC7" 
                             BorderThickness="1.5"
                             VerticalContentAlignment="Center"
                             FontSize="13"/>

                <Button x:Name="btnIniciarSesion" Content="Iniciar Sesión" 
                        Background="#5B5EC7" 
                        Foreground="White" 
                        Height="45"
                        FontWeight="Bold"
                        BorderThickness="0"
                        Cursor="Hand" Click="btnIniciarSesion_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="8"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <TextBlock Margin="0,20,0,0" 
                           HorizontalAlignment="Center"
                           FontSize="12" MouseLeftButtonDown="TextBlock_MouseLeftButtonDown" Foreground="#5B5EC7">
                        Crear Cuenta
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>