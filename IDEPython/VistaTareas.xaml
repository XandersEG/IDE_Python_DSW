<Window x:Class="IDEPython.VistaTareas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="#5B5EC7"
        Title="Enunciados del Curso" Height="650" Width="900"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Margin="35,25,35,20">
            <TextBlock Text="Curso: Programación" 
                       FontSize="16" 
                       Foreground="#D1D2FF" 
                       FontWeight="SemiBold"/>
            <TextBlock Text="Enunciados Disponibles" 
                       FontSize="30" 
                       FontWeight="Bold" 
                       Foreground="White"/>
        </StackPanel>

        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="20" 
                Margin="25,0,25,25">
            <Border.Effect>
                <DropShadowEffect BlurRadius="25" Direction="270" ShadowDepth="4" Opacity="0.2"/>
            </Border.Effect>

            <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="15">
                <ItemsControl x:Name="icTareas">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="10,5,10,10" 
                                    Background="#FBFBFF" 
                                    BorderBrush="#ECECFF"
                                    BorderThickness="1"
                                    CornerRadius="12">

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="20,15">
                                        <TextBlock Text="{Binding Titulo}" 
                                                   FontSize="18" 
                                                   FontWeight="Bold" 
                                                   Foreground="#3F4185"/>
                                        <TextBlock Text="{Binding Descripcion}" 
                                                   FontSize="13" 
                                                   Foreground="Gray" 
                                                   TextWrapping="Wrap"
                                                   Margin="0,5,0,0"/>
                                    </StackPanel>

                                    <Button Grid.Column="1" 
                                            Content="RESOLVER" 
                                            Background="#5B5EC7" 
                                            Foreground="White" 
                                            Width="120" 
                                            Height="40"
                                            Margin="20"
                                            FontWeight="Bold"
                                            BorderThickness="0"
                                            Cursor="Hand">
                                        <Button.Resources>
                                            <Style TargetType="Border">
                                                <Setter Property="CornerRadius" Value="8"/>
                                            </Style>
                                        </Button.Resources>
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>