<Window x:Class="IDEPython.VistaCursos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Background="#5B5EC7"
        Title="Cursos" Height="650" Width="950"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Encabezado con Binding al nombre del usuario -->
        <Grid Margin="30,20,30,15">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Bienvenido," FontSize="14" Foreground="#D1D2FF"/>
                <TextBlock Text="{Binding NombreUsuario}" FontSize="26" FontWeight="Bold" Foreground="White"/>
            </StackPanel>

            <Button x:Name="btnVolverAlLogin" Content="Cerrar Sesión" 
                    Foreground="#5B5EC7" Background="White" Height="35" Width="110"
                    FontWeight="Bold" BorderThickness="0" HorizontalAlignment="Right"
                    Cursor="Hand" Click="btnVolverAlLogin_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <!-- Cuerpo Blanco con Scroll General -->
        <Border Grid.Row="1" Background="White" CornerRadius="25,25,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="25,10,25,30">

                    <!-- SECCIÓN DE CURSOS -->
                    <TextBlock Text="Cursos Inscritos" FontSize="20" FontWeight="Bold" 
                               Foreground="#5B5EC7" Margin="12,20,12,10"/>

                    <ItemsControl x:Name="icCursos">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="240" Height="160" Margin="10" Background="#F8F9FF" 
                                        BorderBrush="#E8EAF6" BorderThickness="1" CornerRadius="15">
                                    <Grid Margin="18">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Border Background="#5B5EC7" HorizontalAlignment="Left" Padding="7,3" CornerRadius="5">
                                            <TextBlock Text="{Binding Codigo}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                        </Border>

                                        <TextBlock Grid.Row="1" Text="{Binding Nombre}" FontSize="16" FontWeight="Bold" 
                                                   Foreground="#3F4185" TextWrapping="Wrap" Margin="0,10,0,0"/>

                                        <Button Grid.Row="2" Content="Continuar" Background="#5B5EC7" Foreground="White" 
                                                Height="32" FontWeight="Bold" Click="VerTareasCurso_Click">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="7"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Margin="12,30" Background="#E8EAF6" Height="1"/>

                    <!-- SECCIÓN DE PROYECTOS (Igual a Cursos) -->
                    <TextBlock Text="Mis Proyectos" FontSize="20" FontWeight="Bold" 
                               Foreground="#5B5EC7" Margin="12,0,12,10"/>

                    <ItemsControl x:Name="icProyectos">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="brdProyecto" Width="240" Height="160" Margin="10" 
                                        Background="#F8F9FF" BorderBrush="#E8EAF6" 
                                        BorderThickness="1" CornerRadius="15">
                                    <Grid Margin="18">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Border x:Name="badgeTipo" Background="#3F4185" HorizontalAlignment="Left" Padding="7,3" CornerRadius="5">
                                            <TextBlock Text="PROYECTO" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                        </Border>

                                        <TextBlock Grid.Row="1" Text="{Binding Titulo}" FontSize="16" FontWeight="Bold" 
                                                   Foreground="#3F4185" TextWrapping="Wrap" Margin="0,10,0,0"/>

                                        <Button x:Name="btnAccion" Grid.Row="2" Content="Abrir IDE" 
                                                Background="#3F4185" Foreground="White" 
                                                Height="32" FontWeight="Bold">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="7"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- Trigger para la tarjeta de Crear Proyecto -->
                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Id}" Value="-1">
                                        <Setter TargetName="btnAccion" Property="Content" Value="+ NUEVO"/>
                                        <Setter TargetName="btnAccion" Property="Background" Value="#28A745"/>
                                        <Setter TargetName="badgeTipo" Property="Background" Value="#28A745"/>
                                        <Setter TargetName="brdProyecto" Property="Background" Value="#F0FFF4"/>
                                        <Setter TargetName="brdProyecto" Property="BorderBrush" Value="#28A745"/>
                                    </DataTrigger>
                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>