<Window x:Class="IDEPython.VistaCursos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Background="#5B5EC7"
        Title="Cursos" Height="650" Width="950"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Encabezado fuera del panel blanco -->
        <StackPanel Margin="40,30,40,20">
            <TextBlock Text="Bienvenido" 
                       FontSize="16" 
                       Foreground="#D1D2FF" 
                       FontWeight="SemiBold"/>

            <TextBlock x:Name="hola2"
                       Text="{Binding userName}"
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="White"/>
        </StackPanel>

        <Border Grid.Row="1" 
                Background="White" 
                CornerRadius="25,25,0,0" 
                Margin="0,10,0,0">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Direction="90" ShadowDepth="2" Opacity="0.1"/>
            </Border.Effect>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Text="Cursos Inscritos" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           Foreground="#5B5EC7" 
                           Margin="40,30,40,10"/>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="25,10,25,25">
                    <ItemsControl x:Name="icCursos">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel HorizontalAlignment="Left"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>

                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="270" 
                                        Height="190" 
                                        Margin="12" 
                                        Background="#F8F9FF" 
                                        BorderBrush="#E8EAF6"
                                        BorderThickness="1"
                                        CornerRadius="18">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="10" Direction="270" ShadowDepth="2" Opacity="0.05"/>
                                    </Border.Effect>

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <!-- Badge del Código -->
                                        <Border Margin="20,20,20,0" Background="#5B5EC7" HorizontalAlignment="Left" Padding="10,4" CornerRadius="8">
                                            <TextBlock Text="{Binding Codigo}" 
                                                       Foreground="White" 
                                                       FontSize="11" 
                                                       FontWeight="Bold"/>
                                        </Border>

                                        <!-- Nombre del Curso -->
                                        <TextBlock Grid.Row="1" 
                                                   Text="{Binding Nombre}" 
                                                   FontSize="18" 
                                                   FontWeight="Bold" 
                                                   Foreground="#3F4185" 
                                                   TextWrapping="Wrap" 
                                                   Margin="20,15,20,5"
                                                   VerticalAlignment="Top"/>

                                        <!-- Botón de Acción -->
                                        <Button Grid.Row="2" 
                                                Content="Continuar" 
                                                Background="#5B5EC7" 
                                                Foreground="White" 
                                                Height="38"
                                                Margin="20,0,20,20"
                                                FontWeight="Bold"
                                                BorderThickness="0"
                                                Cursor="Hand">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="10"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</Window>