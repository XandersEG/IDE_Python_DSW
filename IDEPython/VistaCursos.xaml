<Window x:Class="IDEPython.VistaCursos"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Background="#5B5EC7"
        Title="Cursos y proyectos" Height="700" Width="944"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized" MinWidth="602" MinHeight="390">

    <Window.Resources>
        <Style x:Key="RoundedButton" TargetType="Button">
            <Setter Property="Background" Value="#3F4185"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SmallRoundDanger" TargetType="Button">
            <Setter Property="Background" Value="#FFECEC"/>
            <Setter Property="Foreground" Value="#C0392B"/>
            <Setter Property="BorderBrush" Value="#E6B0AA"/>
            <Setter Property="Width" Value="45"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Margin="30,20,30,15">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Bienvenido," FontSize="14" Foreground="#D1D2FF"/>
                <TextBlock Text="{Binding userName}" FontSize="26" FontWeight="Bold" Foreground="White"/>
            </StackPanel>

            <Button x:Name="btnVolverAlLogin" Content="Cerrar Sesión" 
                    Foreground="#5B5EC7" Background="White" Height="35" Width="110"
                    FontWeight="Bold" BorderThickness="0" HorizontalAlignment="Right"
                    Cursor="Hand" Click="btnVolverAlLogin_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="8"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>

        <Border Grid.Row="1" Background="White" CornerRadius="25,25,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="25,10,25,30">

                    <TextBlock Text="Cursos Inscritos" FontSize="20" FontWeight="Bold" 
                               Foreground="#5B5EC7" Margin="12,20,12,10"/>

                    <ItemsControl x:Name="icCursos">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="240" Height="160" Margin="10" Background="#F8F9FF" 
                                        BorderBrush="#E8EAF6" BorderThickness="1" CornerRadius="15">
                                    <Grid Margin="18">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Border Background="#5B5EC7" HorizontalAlignment="Left" Padding="7,3" CornerRadius="5">
                                            <TextBlock Text="{Binding Code}" Foreground="White" FontSize="10" FontWeight="Bold"/>
                                        </Border>

                                        <TextBlock Grid.Row="1" Text="{Binding Name}" FontSize="16" FontWeight="Bold" 
                                                   Foreground="#3F4185" TextWrapping="Wrap" Margin="0,10,0,0"/>

                                        <Button Grid.Row="2" Content="Continuar" Background="#5B5EC7" Foreground="White" 
                                                Height="32" FontWeight="Bold" Click="VerTareasCurso_Click">
                                            <Button.Resources>
                                                <Style TargetType="Border">
                                                    <Setter Property="CornerRadius" Value="7"/>
                                                </Style>
                                            </Button.Resources>
                                        </Button>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <Separator Margin="12,30" Background="#E8EAF6" Height="1"/>

                    <TextBlock Text="Mis Proyectos" FontSize="20" FontWeight="Bold" 
                               Foreground="#5B5EC7" Margin="12,0,12,10"/>

                    <ItemsControl x:Name="icProyectos">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border x:Name="brdProyecto" Width="240" Height="160" Margin="10" 
                                        Background="#F8F9FF" BorderBrush="#E8EAF6" 
                                        BorderThickness="1" CornerRadius="15">
                                    <Grid>
                                        <!-- delete button top-right -->
                                        <Button x:Name="btnEliminarProyecto" Content="Delete" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="17"
                                                Click="EliminarProyecto_Click" Style="{StaticResource SmallRoundDanger}" />
                                        <Grid Margin="20">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="*"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <Border x:Name="badgeTipo" Background="#3F4185" HorizontalAlignment="Left" Padding="7,3" CornerRadius="5">
                                            <TextBlock Text="PROYECTO" Foreground="White" FontSize="10" FontWeight="Bold" Height="15"/>
                                        </Border>

                                        <TextBlock Grid.Row="1" Text="{Binding Name}" FontSize="16" FontWeight="Bold" 
                                                   Foreground="#3F4185" TextWrapping="Wrap" Margin="0,10,0,0"/>
                                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
                                            <Button x:Name="btnAccion" Content="Abrir proyecto" Click="AbrirProyecto_Click" Margin="0,0,6,0" Style="{StaticResource RoundedButton}"/>
                                        </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>

                                <DataTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Name}" Value="+ NUEVO">
                                        <Setter TargetName="btnAccion" Property="Content" Value="+ NUEVO"/>
                                        <Setter TargetName="btnAccion" Property="Background" Value="DarkGray"/>
                                        <Setter TargetName="badgeTipo" Property="Background" Value="DarkGray"/>
                                        <Setter TargetName="btnEliminarProyecto" Property="Visibility" Value="Collapsed"/>
                                        <Setter TargetName="brdProyecto" Property="Background" Value="#F8F9FF"/>
                                        <Setter TargetName="brdProyecto" Property="BorderBrush" Value="#E8EAF6"/>
                                    </DataTrigger>

                                </DataTemplate.Triggers>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>